# Product data provider: "mock" (default) or "off" (Open Food Facts)
PRODUCT_PROVIDER=mock

# Open Food Facts user agent (required when PRODUCT_PROVIDER=off)
# Format: AppName/Version (contact@example.com)
OFF_USER_AGENT=Nutri/0.1 (hello@example.com)

# Optional: Supabase (for persisting scan history server-side)
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
